# ============================================================================
# monitoramento-sei — copie para .env e preencha. .env é gitignored.
# ============================================================================

# --- Login do SEI Acesso Externo (conta única do Rodrigo) ---------------------
SEI_LOGIN_URL=https://sei.anatel.gov.br/sei/controlador_externo.php?acao=usuario_externo_logar&acao_origem=usuario_externo_logar&id_orgao_acesso_externo=0
SEI_EMAIL=
SEI_PASSWORD=

# --- Captura do código 2FA do SEI (IMAP Gmail, somente leitura) ---------------
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
# Senha de app de 16 caracteres (Conta Google > Segurança > Senhas de app; exige 2FA)
IMAP_APP_PASSWORD=
SEI_CODE_FROM=naoresponder_sei@anatel.gov.br
SEI_CODE_TTL_MIN=10

# --- Navegador (Playwright) ---------------------------------------------------
# true = sem janela (servidor). Validar Turnstile headless na VPS (ver DEPLOY.md).
HEADLESS=true
SEI_STATE_PATH=state/sei_state.json

# --- Monitoramento de Intimações ----------------------------------------------
# Webhook do fluxo do Power Automate que posta no grupo do Teams.
TEAMS_WEBHOOK_INTIMACOES_URL=
TEAMS_WEBHOOK_STYLE=text
INTIMACOES_DB_PATH=state/intimacoes.db
INTIMACOES_RUN_PAGINAS=1
INTIMACOES_BASELINE_PAGINAS=1
INTIMACOES_SEED_MAX=50
TZ_DISPLAY=America/Sao_Paulo

# --- SharePoint / Microsoft Graph (Fase 1b — cross-check de clientes) ----------
# App "SCM VISTORIAS" (Sites.ReadWrite.All). Se vazio, o bot segue sem cross-check.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
