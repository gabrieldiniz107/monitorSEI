# ============================================================================
# monitoramento-sei — copie para .env e preencha. .env é gitignored.
# ============================================================================

# --- Login do SEI Acesso Externo (conta única do Rodrigo) ---------------------
SEI_LOGIN_URL=https://sei.anatel.gov.br/sei/controlador_externo.php?acao=usuario_externo_logar&acao_origem=usuario_externo_logar&id_orgao_acesso_externo=0
SEI_EMAIL=
SEI_PASSWORD=

# --- Captura do código 2FA do SEI (IMAP Gmail, somente leitura) ---------------
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
# Senha de app de 16 caracteres (Conta Google > Segurança > Senhas de app; exige 2FA)
IMAP_APP_PASSWORD=
SEI_CODE_FROM=naoresponder_sei@anatel.gov.br
SEI_CODE_TTL_MIN=10

# --- Navegador (Playwright) ---------------------------------------------------
# true = sem janela (servidor). Validar Turnstile headless na VPS (ver DEPLOY.md).
HEADLESS=true
SEI_STATE_PATH=state/sei_state.json

# --- Monitoramento de Intimações ----------------------------------------------
# Webhook do fluxo do Power Automate que posta no grupo do Teams.
TEAMS_WEBHOOK_INTIMACOES_URL=
TEAMS_WEBHOOK_STYLE=text
INTIMACOES_DB_PATH=state/intimacoes.db
INTIMACOES_RUN_PAGINAS=1
INTIMACOES_BASELINE_PAGINAS=1
INTIMACOES_SEED_MAX=50
TZ_DISPLAY=America/Sao_Paulo

# --- SharePoint / Microsoft Graph (Fase 1b — cross-check de clientes) ----------
# App "SCM VISTORIAS" (Sites.ReadWrite.All). Se vazio, o bot segue sem cross-check.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# --- OpenAI (Fase 2 — resumo) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Power Automate: rascunho na caixa do Juridico (Fase 2) ---
POWERAUTOMATE_RASCUNHO_URL=

# --- Alertas de ERRO: DM no Teams (Graph delegado, igual as vistorias CFT/CREA) -
# Erro de automacao vai para a DM do responsavel tecnico, NUNCA para o grupo do
# Juridico. Exige login device-code UMA vez:  python -m seibot.teams_dm --login
# (chat no Graph nao funciona app-only; precisa Chat.Create + ChatMessage.Send
#  DELEGADOS no app "SCM VISTORIAS" + "Allow public client flows" = Yes).
TEAMS_DEV_EMAIL=gabriel.albuquerque@scmengenharia.com.br
GRAPH_TOKEN_CACHE=state/.graph_token.json
TEAMS_CHAT_CACHE=state/.teams_chats.json
# Alternativa por webhook (Power Automate). So' e' usada se TEAMS_DEV_EMAIL vazio.
TEAMS_WEBHOOK_ERROS_URL=

# --- ARMAR a tratativa automatica (Fase 2) ------------------------------------
# TRATAR_AUTO=true libera o `tratar --modo real`, que DA CIENCIA sozinho e INICIA
# PRAZO LEGAL (irreversivel). Sem isso o comando recusa rodar. Ligue so' quando o
# fluxo estiver validado e o webhook de erros configurado.
TRATAR_AUTO=false
